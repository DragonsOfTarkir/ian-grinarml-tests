{
  "info": {
    "name": "RateDoc Cities API Tests",
    "_postman_id": "11111111-2222-3333-4444-555555555555",
    "description": "CRUD tests for Cities endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create City",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/cities",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "cities"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"TestCity_{{$timestamp}}\",\n  \"country_id\": 1\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 or 201\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "let responseData;",
              "try {",
              "    responseData = pm.response.json();",
              "    console.log(\"Create City Response:\", responseData);",
              "} catch (e) {",
              "    console.log(\"Non-JSON response:\", pm.response.text());",
              "}",
              "",
              "pm.test(\"City created successfully\", function () {",
              "    pm.expect(responseData).to.have.property(\"name\");",
              "});",
              "",
              "if (responseData && (responseData.id || responseData._id)) {",
              "    pm.environment.set(\"cityId\", responseData.id || responseData._id);",
              "    pm.environment.set(\"cityName\", responseData.name);",
              "} else {",
              "    console.log(\"City ID not found:\", responseData);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get City by ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/cities/{{cityId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "cities", "{{cityId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "let responseData = pm.response.json();",
              "",
              "pm.test(\"Correct city returned\", function () {",
              "    pm.expect(responseData.id || responseData._id)",
              "        .to.eql(pm.environment.get(\"cityId\"));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Update City",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/cities/{{cityId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "cities", "{{cityId}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"UpdatedCity_{{$timestamp}}\",\n  \"country_id\": 1\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "let responseData = pm.response.json();",
              "",
              "pm.test(\"City updated successfully\", function () {",
              "    pm.expect(responseData.name).to.exist;",
              "});",
              "",
              "pm.environment.set(\"updatedCityName\", responseData.name);"
            ]
          }
        }
      ]
    },
    {
      "name": "Verify Updated City",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/cities/{{cityId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "cities", "{{cityId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "let responseData = pm.response.json();",
              "",
              "pm.test(\"City name is updated\", function () {",
              "    pm.expect(responseData.name)",
              "        .to.eql(pm.environment.get(\"updatedCityName\"));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete City",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/api/v1/cities/{{cityId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "cities", "{{cityId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 or 204\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Verify City Deleted",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/cities/{{cityId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "cities", "{{cityId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"City no longer exists\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([404, 422]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "List Cities",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/cities",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "cities"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "let responseData = pm.response.json();",
              "",
              "pm.test(\"Response is an array\", function () {",
              "    pm.expect(responseData).to.be.an(\"array\");",
              "});"
            ]
          }
        }
      ]
    }
  ]
}